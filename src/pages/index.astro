---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { site, pillars, categories } from '../config';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Mỗi category lấy 5 bài mới nhất.
const columns = categories.map((cat) => ({
  ...cat,
  posts: allPosts.filter((p) => p.data.category === cat.slug).slice(0, 5),
}));
---
<BaseLayout>
  <section class="hero">
    <h1>Xin chào, tôi là Nguyễn Ngọc Vũ</h1>
    <p class="tagline">{site.tagline}</p>
    <p>
      Một người đam mê công nghệ, yêu sự tự do và đang học cách đưa Phật pháp vào
      đời sống. Tôi chọn internet để được tự do, chọn tạo giá trị bền vững để tìm bình yên —
      giúp mọi người sống an lạc, giàu có và hạnh phúc hơn.
    </p>
    <div class="btn-row">
      <a href="/blog" class="btn">Đọc blog</a>
      <a href="/gioi-thieu" class="btn ghost">Về tôi</a>
    </div>
    <div class="chips" style="margin-top:28px">
      {site.author.nicknames.map((n) => (
        <div class="chip"><strong>{n.label}</strong> · <span>{n.field}</span></div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Tôi đang làm gì?</h2>
    <p class="sub">Ba việc tôi dành tâm huyết mỗi ngày</p>
    <div class="grid">
      {pillars.map((p) => (
        <a href={p.link} class="card" style="display:block; color:inherit">
          <div class="icon">{p.icon}</div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Bài viết mới</h2>
    <p class="sub">Góc chia sẻ về Phật pháp, công nghệ và phát triển bản thân</p>
    <div class="cat-columns">
      {columns.map((col) => (
        <div class="cat-column">
          <a href={`/blog/category/${col.slug}`} class="cat-column-head">
            <h3>{col.name}</h3>
          </a>
          <ul class="post-list">
            {col.posts.map((post) => <PostCard post={post} />)}
          </ul>
        </div>
      ))}
    </div>
    <div class="btn-row" style="margin-top:28px">
      <a href="/blog" class="btn ghost">Xem tất cả bài viết</a>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
    align-items: start;
  }
  .cat-column-head {
    display: block;
    padding-bottom: 0.6rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--accent);
    color: inherit;
  }
  .cat-column-head h3 { margin: 0; color: var(--accent); font-size: 1.15rem; }
  .cat-column .post-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.4rem; }
  @media (max-width: 900px) {
    .cat-columns { grid-template-columns: 1fr; gap: 2.4rem; }
  }
</style>
