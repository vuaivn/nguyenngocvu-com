---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../config';
import { getCollection } from 'astro:content';
import { formatDate, categoryName } from '../../utils';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog" description="Tất cả bài viết về Phật pháp, công nghệ AI và phát triển bản thân.">
  <section class="section">
    <h1 style="text-align:center; font-size:2.1rem; margin-bottom:8px">Blog</h1>
    <p class="sub">Chia sẻ về Phật pháp, công nghệ và hành trình phát triển bản thân</p>
    <div class="cat-pills">
      <a href="/blog" class="active">Tất cả</a>
      {categories.map((c) => (
        <a href={`/blog/category/${c.slug}`}>{c.name}</a>
      ))}
    </div>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item">
          <div class="meta">
            <span class="cat">{categoryName(post.data.category)}</span>
            <span>{formatDate(post.data.pubDate)}</span>
          </div>
          <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
