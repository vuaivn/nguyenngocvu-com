---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { categories, site } from '../../../config';
import { getCollection } from 'astro:content';
import { categoryName } from '../../../utils';

export async function getStaticPaths() {
  return categories.map((c) => ({
    params: { cat: c.slug },
    props: { cat: c },
  }));
}

const { cat } = Astro.props;
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === cat.slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: cat.name,
    description: cat.desc,
    url: new URL(`/blog/category/${cat.slug}/`, site.url).href,
    inLanguage: 'vi-VN',
  },
];
---
<BaseLayout title={cat.name} description={cat.desc} jsonld={jsonld}>
  <section class="section">
    <h1 style="text-align:center; font-size:2.1rem; margin-bottom:8px">{cat.name}</h1>
    <p class="sub">{cat.desc}</p>
    <div class="cat-pills">
      <a href="/blog">Tất cả</a>
      {categories.map((c) => (
        <a href={`/blog/category/${c.slug}`} class={c.slug === cat.slug ? 'active' : ''}>{c.name}</a>
      ))}
    </div>
    <ul class="post-list grid-list">
      {posts.map((post) => <PostCard post={post} />)}
    </ul>
  </section>
</BaseLayout>
