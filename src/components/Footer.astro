---
import { site } from '../config';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="social">
    <a href={site.social.youtube} target="_blank" rel="noopener">YouTube</a>
    <a href={site.social.facebook} target="_blank" rel="noopener">Facebook</a>
    <a href={`mailto:${site.email}`}>Email</a>
  </div>
  <div class="site-network">
    <span>Website khác:</span>
    <a href="https://vu.ai.vn" target="_blank" rel="me noopener">vu.ai.vn</a>
  </div>
  <p>© {year} {site.name} · {site.tagline}</p>
</footer>
