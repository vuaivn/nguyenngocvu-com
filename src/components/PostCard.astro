---
import { formatDate, categoryName, categoryImage, readingTime } from '../utils';

interface Props {
  post: any;
  showImage?: boolean;
}
const { post, showImage = true } = Astro.props;
const img = post.data.heroImage ?? categoryImage(post.data.category);
const alt = post.data.heroAlt ?? `Minh họa cho bài viết: ${post.data.title}`;
const mins = readingTime(post.body);
---
<li class="post-item">
  {showImage && (
    <a href={`/blog/${post.slug}`} aria-label={post.data.title}>
      <img class="post-thumb" src={img} alt={alt} loading="lazy" width="1200" height="630" />
    </a>
  )}
  <div class="meta">
    <span class="cat">{categoryName(post.data.category)}</span>
    <span>{formatDate(post.data.pubDate)}</span>
    <span>· {mins} phút đọc</span>
  </div>
  <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
</li>
